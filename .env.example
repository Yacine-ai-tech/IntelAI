# IntelAI example environment file
# Copy to .env and update values.

ENVIRONMENT=development
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,http://localhost:8000,http://localhost:8501

POSTGRES_URL=postgresql://omniintel:change_me_postgres_password@localhost:5432/intelai
CHROMA_DB_PATH=./chroma_db

GROQ_API_KEY=your_groq_api_key_here
TAVILY_API_KEY=your_tavily_api_key_here

SECRET_KEY=change_this_to_a_secure_random_string_in_production
SESSION_TIMEOUT=3600
ALLOW_INSECURE_DEFAULT_USERS=false
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

N8N_BASE_URL=http://localhost:5678
N8N_API_KEY=
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_password
N8N_WEBHOOK_HOST_OVERRIDE=
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

CLOUDFLARE_DOMAIN=ysiddo-ai-projects.app
PUBLIC_API_URL=https://api.ysiddo-ai-projects.app
PUBLIC_FRONTEND_URL=https://app.ysiddo-ai-projects.app
PUBLIC_N8N_URL=https://workflows.ysiddo-ai-projects.app
TUNNEL_URL=
CLOUDFLARE_TOKEN=
CLOUDFLARE_PERMANENT_TOKEN=

FEATURE_VOICE=true
FEATURE_N8N=true
FEATURE_RAG=true
FEATURE_MONTE_CARLO=true

# ── 2026 Stack Upgrade ──────────────────────────────────────────────────────
LLM_DEFAULT=groq/llama-3.3-70b-versatile
LLM_REASONING=anthropic/claude-sonnet-4-6
LLM_JUDGE=anthropic/claude-haiku-4-5
LLM_LOCAL=ollama/llama3.3

ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Hybrid RAG (BGE-large + BM25 + RRF + BGE Reranker)
USE_HYBRID_RETRIEVAL=false
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# GraphRAG-lite: entity-graph ranking of KPI records for multi-hop queries (opt-in)
USE_GRAPH_RAG=false

# Vector store: chroma (dev) | qdrant (prod)
VECTOR_STORE=chroma
QDRANT_URL=
QDRANT_API_KEY=

# ── Third-Party Integrations ──────────────────────────────────────────────────
CLICKUP_API_KEY=
CLICKUP_TEAM_ID=
CLICKUP_WORKSPACE_ID=
GOOGLE_API_KEY=
GOOGLE_CREDENTIALS_PATH=
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_CALENDAR_CALENDAR_ID=
SLACK_API_TOKEN=
SLACK_WORKSPACE_ID=
SLACK_CHANNEL_ID=
