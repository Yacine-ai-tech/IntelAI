# IntelAI example environment — copy to .env and fill in.

# ── App ─────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
FASTAPI_HOST=0.0.0.0
FASTAPI_PORT=8000
FRONTEND_URL=http://localhost:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# ── Localization ─────────────────────────────────────────────────────────────
# UI/insight language: en | fr (bilingual). Affects executive summaries + number formats.
DEFAULT_LANGUAGE=en
# Display currency (ISO 4217) for KPI/insight formatting: USD | EUR | GBP | XOF (FCFA) | …
# Presentation only — does not perform FX conversion. e.g. XOF renders "1,2 Md FCFA" in fr.
CURRENCY=USD

# ── Database (Postgres) + vector store ──────────────────────────────────────
POSTGRES_URL=postgresql://intelai:change_me@localhost:5432/intelai
CHROMA_DB_PATH=./chroma_db
# Vector store: chroma (dev) | qdrant (prod)
VECTOR_STORE=chroma
QDRANT_URL=
QDRANT_API_KEY=

# ── LLM providers (Groq required; Anthropic/OpenAI optional) ────────────────
GROQ_API_KEY=your_groq_api_key_here
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
TAVILY_API_KEY=your_tavily_api_key_here
# Multi-provider tiers (LiteLLM router)
LLM_DEFAULT=groq/llama-3.3-70b-versatile
LLM_REASONING=anthropic/claude-sonnet-4-6
LLM_JUDGE=anthropic/claude-haiku-4-5

# ── Retrieval ───────────────────────────────────────────────────────────────
# Hybrid RAG (BGE-large + BM25 + RRF + BGE reranker).
# On the copilot's first query this downloads the BGE models (~1.3 GB); set false for a
# lightweight setup where models aren't cached.
USE_HYBRID_RETRIEVAL=true
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
# GraphRAG-lite: entity-graph ranking of KPI records for multi-hop queries (cheap, on).
USE_GRAPH_RAG=true

# ── Auth ────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_to_a_secure_random_string_in_production
SESSION_TIMEOUT=3600
ALLOW_INSECURE_DEFAULT_USERS=false
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=

# ── Feature flags ───────────────────────────────────────────────────────────
FEATURE_RAG=true
FEATURE_MONTE_CARLO=true
