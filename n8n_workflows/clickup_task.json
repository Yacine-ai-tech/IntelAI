{
  "name": "OmniIntelOS - ClickUp Tasks",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "clickup-task",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-clickup",
      "name": "Webhook - ClickUp Task",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "clickup-task"
    },
    {
      "parameters": {
        "list": "={{ $json.list_id }}",
        "name": "={{ $json.name }}",
        "additionalFields": {
          "content": "={{ $json.description }}",
          "priority": "={{ $json.priority }}"
        }
      },
      "id": "clickup-create",
      "name": "ClickUp - Create Task",
      "type": "n8n-nodes-base.clickUp",
      "typeVersion": 1,
      "position": [500, 300],
      "credentials": {
        "clickUpApi": {
          "id": "REPLACE_WITH_CLICKUP_CREDENTIAL_ID",
          "name": "ClickUp account"
        }
      }
    }
  ],
  "connections": {
    "Webhook - ClickUp Task": {
      "main": [
        [
          {
            "node": "ClickUp - Create Task",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
