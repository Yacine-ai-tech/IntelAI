{
  "name": "OmniIntelOS - Google Sheets Push",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "sheets-push",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-sheets",
      "name": "Webhook - Sheets Push",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "sheets-push"
    },
    {
      "parameters": {
        "operation": "appendOrUpdate",
        "documentId": {
          "__rl": true,
          "value": "={{ $json.spreadsheet_id }}",
          "mode": "id"
        },
        "sheetName": {
          "__rl": true,
          "value": "={{ $json.sheet_name }}",
          "mode": "name"
        },
        "columns": {
          "mappingMode": "autoMapInputData"
        },
        "options": {}
      },
      "id": "sheets-write",
      "name": "Google Sheets - Append Rows",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.5,
      "position": [500, 300],
      "credentials": {
        "googleSheetsOAuth2Api": {
          "id": "REPLACE_WITH_GOOGLE_CREDENTIAL_ID",
          "name": "Google OAuth2"
        }
      }
    }
  ],
  "connections": {
    "Webhook - Sheets Push": {
      "main": [
        [
          {
            "node": "Google Sheets - Append Rows",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "Company OS" }]
}
