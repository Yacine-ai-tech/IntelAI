{
  "name": "OmniIntelOS - Drive Upload",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "drive-upload",
        "responseMode": "onReceived",
        "options": {}
      },
      "id": "webhook-drive",
      "name": "Webhook - Drive Upload",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 1,
      "position": [250, 300],
      "webhookId": "drive-upload"
    },
    {
      "parameters": {
        "name": "={{ $json.filename }}",
        "folderId": "={{ $json.folder_id }}",
        "options": {}
      },
      "id": "drive-upload",
      "name": "Google Drive - Upload",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [500, 300],
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "REPLACE_WITH_DRIVE_CREDENTIAL_ID",
          "name": "Google Drive account"
        }
      }
    }
  ],
  "connections": {
    "Webhook - Drive Upload": {
      "main": [
        [
          {
            "node": "Google Drive - Upload",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  }
}
